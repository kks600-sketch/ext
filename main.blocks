<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="{g$SVqmz^.$_QVwL{yhv" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="QG5F|]apME_0sQ~06:T+"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace easyMotor {" line1="" line2="    // ตัวเลือกทิศทางเพื่อสร้างเป็นเมนูดรอปดาวน์ในบล็อก" line3="    export enum CarDirection {" line4="        // % block=&quot;เดินหน้า&quot;" line5="        Forward," line6="        // % block=&quot;ถอยหลัง&quot;" line7="        Backward," line8="        // % block=&quot;เลี้ยวซ้าย&quot;" line9="        TurnLeft," line10="        // % block=&quot;เลี้ยวขวา&quot;" line11="        TurnRight" line12="    }" line13="" line14="    /**" line15="     * สั่งงานมอเตอร์ของรถให้เคลื่อนที่ตามทิศทางและความเร็วที่กำหนด" line16="     * @param direction ทิศทางที่ต้องการให้รถวิ่ง" line17="     * @param speed ความเร็วเป็นเปอร์เซ็นต์ 0 ถึง 100, eg: 50" line18="     */" line19="    // % block=&quot;ควบคุมรถ ให้ %direction ความเร็ว %speed %%&quot;" line20="    // % speed.min=0 speed.max=100" line21="    export function move(direction: CarDirection, speed: number): void {" line22="        // แปลงความเร็วจาก 0-100% ให้เป็นสัญญาณอนาล็อก 0-1023 ของ micro:bit" line23="        let pwnVal = pins.map(speed, 0, 100, 0, 1023)" line24="" line25="        if (direction === CarDirection.Forward) {" line26="            // มอเตอร์ซ้ายเดินหน้า (P13=1, P14=PWM) | มอเตอร์ขวาเดินหน้า (P15=1, P16=PWM)" line27="            pins.digitalWritePin(DigitalPin.P13, 1)" line28="            pins.analogWritePin(AnalogPin.P14, pwnVal)" line29="            pins.digitalWritePin(DigitalPin.P15, 1)" line30="            pins.analogWritePin(AnalogPin.P16, pwnVal)" line31="        }" line32="        else if (direction === CarDirection.Backward) {" line33="            // มอเตอร์ซ้ายถอยหลัง (P13=0, P14=PWM) | มอเตอร์ขวาถอยหลัง (P15=0, P16=PWM)" line34="            pins.digitalWritePin(DigitalPin.P13, 0)" line35="            pins.analogWritePin(AnalogPin.P14, pwnVal)" line36="            pins.digitalWritePin(DigitalPin.P15, 0)" line37="            pins.analogWritePin(AnalogPin.P16, pwnVal)" line38="        }" line39="        else if (direction === CarDirection.TurnLeft) {" line40="            // เลี้ยวซ้าย: มอเตอร์ซ้ายถอยหลัง | มอเตอร์ขวาเดินหน้า" line41="            pins.digitalWritePin(DigitalPin.P13, 0)" line42="            pins.analogWritePin(AnalogPin.P14, pwnVal)" line43="            pins.digitalWritePin(DigitalPin.P15, 1)" line44="            pins.analogWritePin(AnalogPin.P16, pwnVal)" line45="        }" line46="        else if (direction === CarDirection.TurnRight) {" line47="            // เลี้ยวขวา: มอเตอร์ซ้ายเดินหน้า | มอเตอร์ขวาถอยหลัง" line48="            pins.digitalWritePin(DigitalPin.P13, 1)" line49="            pins.analogWritePin(AnalogPin.P14, pwnVal)" line50="            pins.digitalWritePin(DigitalPin.P15, 0)" line51="            pins.analogWritePin(AnalogPin.P16, pwnVal)" line52="        }" line53="    }" line54="" line55="    /**" line56="     * สั่งให้รถหยุดวิ่งทันทีโดยการตัดกระแสไฟมอเตอร์ทุกดวง" line57="     */" line58="    // % block=&quot;หยุดรถทันที&quot;" line59="    export function stop(): void {" line60="        pins.digitalWritePin(DigitalPin.P13, 0)" line61="        pins.digitalWritePin(DigitalPin.P14, 0)" line62="        pins.digitalWritePin(DigitalPin.P15, 0)" line63="        pins.digitalWritePin(DigitalPin.P16, 0)" line64="    }" line65="}" numlines="66"></mutation></block></statement></block></xml>