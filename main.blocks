<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="C^FYa;i!Hq*HcqK%yls]" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="]IC]C/B4?yMJr5Xn$LpM"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace customMotor {" line1="" line2="    export enum MotorDir {" line3="        // % block=&quot;เดินหน้า&quot;" line4="        Forward," line5="        // % block=&quot;ถอยหลัง&quot;" line6="        Backward" line7="    }" line8="" line9="    /**" line10="     * สั่งงานมอเตอร์ให้เคลื่อนที่ เดินหน้า หรือ ถอยหลัง" line11="     * @param direction ทิศทางเคลื่อนที่" line12="     * @param speed ความเร็ว 0-100 %, eg: 60" line13="     */" line14="    // % block=&quot;สั่งรถ %direction ความเร็ว %speed %%&quot;" line15="    // % speed.min=0 speed.max=100" line16="    export function move(direction: MotorDir, speed: number): void {" line17="        let pwnVal = pins.map(speed, 0, 100, 0, 1023)" line18="        if (direction === MotorDir.Forward) {" line19="            pins.digitalWritePin(DigitalPin.P13, 1)" line20="            pins.analogWritePin(AnalogPin.P14, pwnVal)" line21="            pins.digitalWritePin(DigitalPin.P15, 1)" line22="            pins.analogWritePin(AnalogPin.P16, pwnVal)" line23="        } else if (direction === MotorDir.Backward) {" line24="            pins.digitalWritePin(DigitalPin.P13, 0)" line25="            pins.analogWritePin(AnalogPin.P14, pwnVal)" line26="            pins.digitalWritePin(DigitalPin.P15, 0)" line27="            pins.analogWritePin(AnalogPin.P16, pwnVal)" line28="        }" line29="    }" line30="" line31="    /**" line32="     * สั่งให้มอเตอร์รถหยุดวิ่งทันที" line33="     */" line34="    // % block=&quot;หยุดรถ&quot;" line35="    export function stop(): void {" line36="        pins.digitalWritePin(DigitalPin.P13, 0)" line37="        pins.digitalWritePin(DigitalPin.P14, 0)" line38="        pins.digitalWritePin(DigitalPin.P15, 0)" line39="        pins.digitalWritePin(DigitalPin.P16, 0)" line40="    }" line41="}" numlines="42"></mutation></block></statement></block></xml>